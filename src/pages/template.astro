---
import SubLayout from "../layouts/SubLayout.astro";
---

<SubLayout langType="ja" title="ページタイトル">
    <article class="page">
        <!-- パンくず -->
        <nav class="page__breadcrumb" aria-label="パンくずリスト">
            <ol>
                <li><a href="/">ホーム</a></li>
                <li aria-current="page">ページタイトル</li>
            </ol>
        </nav>

        <!-- ページヘッダー -->
        <header class="page__header">
            <h1 class="page__title">ページタイトル</h1>
            <p class="page__lead">
                ここにページの概要（リード文）を記述します。下層ページで共通して利用できるテンプレートです。
            </p>
        </header>

        <!-- セクション例 -->
        <section class="page__section">
            <h2 class="page__section-title">セクション見出し</h2>
            <p class="page__text">
                本文エリアのサンプルです。必要に応じてコンポーネントを挿入してください。
            </p>
        </section>

        <section class="page__section">
            <h2 class="page__section-title">セクション見出し</h2>
            <p class="page__text">
                本文エリアのサンプルです。必要に応じてコンポーネントを挿入してください。
            </p>
        </section>
    </article>
</SubLayout>

<style lang="scss">
.page {
  max-width: 1000px;
  margin: 0 auto;
  padding: 40px 24px 80px;

  @include mixin.xsm {
    padding: 24px 16px 56px;
  }

  &__breadcrumb {
    margin-bottom: 24px;
    font-size: 12px;
    color: #666;

    ol {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    li + li::before {
      content: "/";
      margin-right: 8px;
      color: #bbb;
    }

    a {
      color: #0066cc;
      text-decoration: none;

      &:hover {
        text-decoration: underline;
      }
    }

    [aria-current="page"] {
      color: #222;
    }
  }

  &__header {
    margin-bottom: 40px;
    padding-bottom: 20px;
    border-bottom: 1px solid #eaeaea;
  }

  &__title {
    margin: 0 0 12px;
    font-size: 32px;
    font-weight: 700;
    line-height: 1.3;
    color: #1a1a1a;

    @include mixin.xsm {
      font-size: 24px;
    }
  }

  &__lead {
    margin: 0;
    font-size: 15px;
    line-height: 1.8;
    color: #555;
  }

  &__section {
    margin-bottom: 40px;
  }

  &__section-title {
    margin: 0 0 16px;
    font-size: 20px;
    font-weight: 700;
    color: #1a1a1a;
  }

  &__text {
    margin: 0;
    font-size: 14px;
    line-height: 1.9;
    color: #333;
  }
}
</style>
