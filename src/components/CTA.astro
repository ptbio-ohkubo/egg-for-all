---
// Final CTA — email notification signup
---

<section class="cta-section" id="notify">
  <div class="cta-egg-l"></div>
  <div class="cta-egg-r"></div>
  <div class="cta-inner">
    <div class="cta-eyebrow">Pre-Order — 2027</div>
    <h2><em>事前予約</em>を<br />受け付けています</h2>
    <p>
      2027年度の市場投入に向けて着実に進んでいます。<br />
      事前予約いただいた方に優先的にお届けします。
    </p>

    <a href={`${import.meta.env.BASE_URL}reservation`} class="cta-btn">事前予約する →</a>
    <p class="cta-note">
      ご予約のキャンセルはいつでも可能です。
    </p>
  </div>
</section>


<style>
  .cta-section {
    background: linear-gradient(160deg, var(--teal-bg) 0%, var(--teal-d) 100%);
    padding: 130px 48px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .cta-egg-l,
  .cta-egg-r {
    position: absolute;
    border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
    background: rgba(255, 255, 255, 0.05);
  }
  .cta-egg-l {
    width: 320px;
    height: 380px;
    left: -80px;
    top: 50%;
    transform: translateY(-50%);
  }
  .cta-egg-r {
    width: 240px;
    height: 280px;
    right: -40px;
    bottom: -60px;
  }
  .cta-inner {
    position: relative;
    z-index: 1;
    max-width: 680px;
    margin: 0 auto;
  }
  .cta-eyebrow {
    font-size: 11px;
    letter-spacing: 3px;
    color: var(--gold-l);
    text-transform: uppercase;
    margin-bottom: 24px;
  }
  .cta-section h2 {
    font-family: "Zen Kaku Gothic New", sans-serif;
    font-size: 44px;
    font-weight: 700;
    color: white;
    line-height: 1.3;
    margin-bottom: 20px;
    letter-spacing: -0.3px;
  }
  .cta-section h2 em {
    font-style: normal;
    color: var(--gold-l);
    background: linear-gradient(transparent 60%, rgba(201, 169, 58, 0.25) 60%);
    padding: 0 4px;
  }
  .cta-section p {
    font-size: 15px;
    color: rgba(255, 255, 255, 0.78);
    line-height: 1.95;
    margin-bottom: 44px;
  }

  .cta-btn {
    display: inline-block;
    background: var(--gold);
    color: white;
    padding: 18px 48px;
    border-radius: 40px;
    font-size: 16px;
    font-weight: 700;
    font-family: inherit;
    text-decoration: none;
    letter-spacing: 0.5px;
    margin-bottom: 20px;
    transition: all 0.2s;
    box-shadow: 0 6px 18px rgba(201, 169, 58, 0.35);
  }
  .cta-btn:hover {
    background: #b89530;
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(201, 169, 58, 0.45);
  }
  .cta-section p.cta-note {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.45);
    margin-bottom: 0;
  }
  .cta-or {
    color: rgba(255, 255, 255, 0.4);
    margin: 32px 0 18px;
    font-size: 13px;
  }
  .cta-links {
    display: flex;
    gap: 20px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .link-w {
    color: rgba(255, 255, 255, 0.75);
    font-size: 14px;
    text-decoration: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.3);
    padding-bottom: 2px;
    transition: all 0.2s;
  }
  .link-w:hover {
    color: white;
    border-color: white;
  }

  @media (max-width: 900px) {
    .cta-section {
      padding: 80px 20px;
    }
    .cta-section h2 {
      font-size: 30px;
    }
    .notify-form {
      flex-direction: column;
    }
  }
</style>
