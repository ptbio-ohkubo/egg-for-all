---
// Research & development partners - Timee LP companies-logos style
const base = import.meta.env.BASE_URL;
const partners = [
  { name: "広島大学", logo: `${base}logos/Hiroshima_univ.png` },
  { name: "プラチナバイオ", logo: `${base}logos/PtBio_yoko_color.png` },
];
---

<section class="partners-section">
  <div class="partners-inner">
    <h3 class="partners-title">
      産学連携・大学発スタートアップで<br />
      <em>22年以上の研究実績</em>を結実
    </h3>

    <p class="partners-subtitle">ぐっとくる文章</p>

    <div class="partners-marquee">
      <div class="partners-track">
        {
          partners.map((p, i) => (
            <>
              <div class="partner-card">
                <img class="partner-logo" src={p.logo} alt={p.name} />
              </div>
              {i < partners.length - 1 && (
                <div class="partner-cross">×</div>
              )}
            </>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .partners-section {
    background: #ffffff;
    padding: 80px 40px 80px 40px;
    position: relative;
    overflow: hidden;
  }
  .partners-inner {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }
  .partners-label {
    font-size: 11px;
    letter-spacing: 3px;
    color: #005e3c;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .partners-title {
    font-family: "Noto Sans JP", sans-serif;
    font-size: 44px;
    font-weight: 700;
    color: var(--dark);
    line-height: 1.5;
    margin-bottom: 0;
  }
  .partners-title em {
    font-style: normal;
    color: #c0392b;
  }

  .partners-subtitle {
    font-family: "Noto Sans JP", sans-serif;
    font-size: 18px;
    font-weight: 400;
    color: rgba(0, 0, 0, 0.6);
    line-height: 1.8;
    margin-top: 20px;
    margin-bottom: 0;
  }

  .partners-marquee {
    padding: 80px 48px 0;
  }
  .partners-track {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0;
    align-items: center;
  }
  .partner-cross {
    font-size: 24px;
    color: rgba(0, 0, 0, 0.25);
    padding: 0 16px;
    user-select: none;
  }
  .partner-card {
    background: white;
    border: none;
    border-radius: 0;
    padding: 32px 24px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .partner-logo {
    max-width: 320px;
    max-height: 140px;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  @media (max-width: 900px) {
    .partners-section {
      padding: 60px 20px;
    }
    .partners-title {
      font-size: 32px;
    }
    .partners-track {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 540px) {
    .partners-track {
      grid-template-columns: 1fr;
    }
  }
</style>
