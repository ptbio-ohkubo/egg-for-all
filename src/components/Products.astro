---
// Products section — image grid with text overlay
const products = [
  {
    name: "プリン・カスタード",
    img: "https://images.unsplash.com/photo-1564589944854-08b59bed61f1?w=800&h=600&fit=crop&q=80&auto=format",
    credit: "Kouji Tsuru / Unsplash",
  },
  {
    name: "クッキー・焼き菓子",
    img: "https://images.unsplash.com/photo-1499636136210-6f4ee915583e?w=800&h=600&fit=crop&q=80&auto=format",
    credit: "Jennifer Pallian / Unsplash",
  },
  {
    name: "蒸しパン・ケーキ",
    img: "https://images.unsplash.com/photo-1742054292312-7bd7d3984b40?w=800&h=600&fit=crop&q=80&auto=format",
    credit: "Mathias Reding / Unsplash",
  },
  {
    name: "ゆでたまご",
    img: "https://images.unsplash.com/photo-1557965983-5b9fc9ab9014?w=800&h=600&fit=crop&q=80&auto=format",
    credit: "Rosalind Chang / Unsplash",
  },
  {
    name: "麺類・惣菜への展開",
    img: "https://images.unsplash.com/photo-1509680859026-7d8cfc6894f4?w=800&h=600&fit=crop&q=80&auto=format",
    credit: "j / Unsplash",
  },
];
---

<section class="products-section" id="products">
  <div class="products-inner">
    <div class="products-header">
      <div class="products-header-left">
        <div class="sec-label">Products</div>
        <h2 class="sec-h">何が<em>食べられるように</em><br />なるの？</h2>
      </div>
      <div class="products-header-right">
        <p class="sec-lead">
          最初は加熱加工食品からお届けします。アレルギー低減卵を適切に加熱することでアレルゲンフリーを実現。(ぐっとくる文章を追加)
        </p>
      </div>
    </div>

    <div class="products-grid">
      {
        products.map((p) => (
          <div class="prod-card">
            <img class="prod-img" src={p.img} alt={p.name} />
            <div class="prod-overlay" />
            <div class="prod-content">
              <h3>{p.name}</h3>
            </div>
          </div>
        ))
      }
    </div>

    <div class="products-note">
      <div class="note-icon"><span class="mdi mdi-lightbulb-on"></span></div>
      <p>
        アレルゲンフリーにするには<strong>適切な加熱</strong>が必要です。そのため最初は加熱加工食品からスタート。生卵の販売は将来の課題ですが、まずプリンやクッキーなど身近な食品からお届けします。普通の卵と比べ<strong>基本的な栄養素はほとんど同じ</strong>です。
      </p>
    </div>
  </div>
</section>

<style>
  .products-section {
    background: var(--cream);
    padding: 110px 48px;
  }
  .products-inner {
    max-width: 1100px;
    margin: 0 auto;
  }
  .products-section .sec-h {
    font-family: "Noto Sans JP", sans-serif;
  }
  .products-section .sec-h em {
    font-style: normal;
  }
  .products-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
    padding-bottom: 64px;
  }
  .products-header-left {
    text-align: left;
  }
  .products-header-right {
    text-align: left;
  }
  .products-header .sec-lead {
    margin: 0;
  }

  /* GRID */
  .products-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    margin-bottom: 40px;
    background: rgba(0, 0, 0, 0.12);
    overflow: hidden;
  }

  /* CARD */
  .prod-card {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #c8c0b4; /* 画像未設定時のプレースホルダー色 */
  }

  /* 画像 */
  .prod-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .prod-card:hover .prod-img {
    transform: scale(1.05);
  }

  /* グラデーションオーバーレイ */
  .prod-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.25);
  }

  /* テキスト：左下寄せ */
  .prod-content {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    padding: 24px 28px;
  }
  .prod-content h3 {
    font-size: 22px;
    font-weight: 700;
    color: white;
    line-height: 1.4;
    letter-spacing: 0.3px;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.4);
  }

  /* NOTE */
  .products-note {
    background: rgba(229, 165, 28, 0.2);
    border-radius: 10px;
    padding: 32px 40px;
    display: flex;
    gap: 20px;
    align-items: center;
    border: 1px solid rgba(210, 60, 40, 0.15);
  }
  .note-icon {
    font-size: 30px;
    flex-shrink: 0;
    color: #c0392b;
    line-height: 1;
  }
  .products-note p {
    font-size: 14px;
    color: var(--text);
    line-height: 1.95;
  }
  .products-note strong {
    color: #c0392b;
    font-weight: 700;
  }

  @media (max-width: 900px) {
    .products-section {
      padding: 70px 20px;
    }
    .products-header {
      grid-template-columns: 1fr;
      gap: 24px;
      padding-bottom: 40px;
    }
    .products-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .products-note {
      flex-direction: column;
      align-items: flex-start;
      padding: 24px;
    }
  }

  @media (max-width: 560px) {
    .products-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
