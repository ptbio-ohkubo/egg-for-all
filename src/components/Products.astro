---
// Products section — Timee LP "募集できる仕事" style grid
const products = [
  {
    icon: "🍮",
    name: "プリン・カスタード",
    desc: "十分な水分と加熱で確実にアレルゲンフリーを実現。第一候補の商品カテゴリです。",
    tag: "開発中",
    tagType: "dev",
  },
  {
    icon: "🍪",
    name: "クッキー・焼き菓子",
    desc: "試作済み。通常品と変わらない美味しさとキユーピーに評価されたレベルです。",
    tag: "試作済み",
    tagType: "trial",
  },
  {
    icon: "🧁",
    name: "蒸しパン・スポンジ",
    desc: "試作済み。適切な水分量と温度の管理で美味しく仕上がっています。",
    tag: "試作済み",
    tagType: "trial",
  },
  {
    icon: "🥚",
    name: "液卵・粉末卵（素材）",
    desc: "食品メーカーへの原材料供給も計画中。アレルギー対応食品の幅が広がります。",
    tag: "計画中",
    tagType: "dev",
  },
  {
    icon: "🍜",
    name: "麺類・惣菜への展開",
    desc: "幅広い加工食品への展開を将来的に予定。卵を使うあらゆる食品を目指します。",
    tag: "将来展開",
    tagType: "future",
  },
  {
    icon: "🏪",
    name: "スーパーでの市販",
    desc: "まずは加工食品から。市販のお菓子としてスーパーに並ぶ日も近づいています。",
    tag: "検討中",
    tagType: "future",
  },
];
---

<section class="products-section" id="products">
  <div class="products-inner">
    <div class="products-header">
      <div class="products-header-left">
        <div class="sec-label">Products</div>
        <h2 class="sec-h">何が<em>食べられるように</em><br />なるの？</h2>
      </div>
      <div class="products-header-right">
        <p class="sec-lead">
          最初は加熱加工食品からお届けします。アレルギー低減卵を適切に加熱することでアレルゲンフリーを実現。試作品はキユーピーからも高く評価されています。
        </p>
      </div>
    </div>

    <div class="products-grid">
      {
        products.map((p) => (
          <div class="prod-card">
            <div class="prod-emoji">{p.icon}</div>
            <h3>{p.name}</h3>
            <p>{p.desc}</p>
            <span class={`prod-tag tag-${p.tagType}`}>{p.tag}</span>
          </div>
        ))
      }
    </div>

    <div class="products-note">
      <div class="note-icon"><span class="mdi mdi-lightbulb-on"></span></div>
      <p>
        アレルゲンフリーにするには<strong>適切な加熱</strong>が必要です。そのため最初は加熱加工食品からスタート。生卵の販売は将来の課題ですが、まずプリンやクッキーなど身近な食品からお届けします。普通の卵と比べ<strong>基本的な栄養素はほとんど同じ</strong>です。
      </p>
    </div>
  </div>
</section>

<style>
  .products-section {
    background: var(--cream);
    padding: 110px 48px;
  }
  .products-inner {
    max-width: 1100px;
    margin: 0 auto;
  }
  .products-section .sec-h {
    font-family: "Noto Sans JP", sans-serif;
  }
  .products-section .sec-h em {
    font-style: normal;
  }
  .products-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
    padding-bottom: 64px;
  }
  .products-header-left {
    text-align: left;
  }
  .products-header-right {
    text-align: left;
  }
  .products-header .sec-lead {
    margin: 0;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 40px;
    /* margin-top は products-header の padding-bottom で確保 */
  }
  .prod-card {
    background: white;
    border-radius: 20px;
    padding: 36px 28px;
    border: 1.5px solid rgba(107, 159, 155, 0.1);
    transition: all 0.3s;
    position: relative;
  }
  .prod-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 48px rgba(107, 159, 155, 0.12);
    border-color: rgba(107, 159, 155, 0.25);
  }
  .prod-emoji {
    font-size: 38px;
    margin-bottom: 20px;
  }
  .prod-card h3 {
    font-size: 17px;
    color: var(--dark);
    margin-bottom: 10px;
    font-weight: 700;
  }
  .prod-card p {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.85;
  }
  .prod-tag {
    display: inline-block;
    margin-top: 16px;
    padding: 5px 14px;
    border-radius: 40px;
    font-size: 11px;
    letter-spacing: 0.8px;
    font-weight: 700;
  }
  .tag-dev {
    background: var(--teal-p);
    color: var(--teal-d);
  }
  .tag-trial {
    background: var(--gold-p);
    color: var(--gold);
  }
  .tag-future {
    background: #f0f0f0;
    color: #999;
  }

  .products-note {
    background: linear-gradient(135deg, #fdecea, #fbd5d0);
    border-radius: 20px;
    padding: 32px 40px;
    display: flex;
    gap: 20px;
    align-items: center;
    border: 1px solid rgba(210, 60, 40, 0.15);
  }
  .note-icon {
    font-size: 30px;
    flex-shrink: 0;
    color: #c0392b;
    line-height: 1;
  }
  .products-note p {
    font-size: 14px;
    color: var(--text);
    line-height: 1.95;
  }
  .products-note strong {
    color: #c0392b;
    font-weight: 700;
  }

  @media (max-width: 900px) {
    .products-section {
      padding: 70px 20px;
    }
    .products-header {
      grid-template-columns: 1fr;
      gap: 24px;
      padding-bottom: 40px;
    }
    .products-grid {
      grid-template-columns: 1fr;
    }
    .products-note {
      flex-direction: column;
      align-items: flex-start;
      padding: 24px;
    }
  }
</style>
