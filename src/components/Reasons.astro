---
// Reasons — BASE FOOD "About" style: header + three concept cards (image + label + sub)
const concepts = [
  {
    emoji: "🧬",
    label: "ピンポイント",
    sub: "原因タンパク「オボムコイド」だけを　DNAレベルで除去",
    theme: "teal",
  },
  {
    emoji: "🛡️",
    label: "安全",
    sub: "3段階の検証で　徹底的に安心を確認",
    theme: "gold",
  },
  {
    emoji: "🍮",
    label: "おいしい",
    sub: "「市販レベル」と評価された　本物の美味しさ",
    theme: "cream",
  },
];
---

<section class="reasons-section" id="reasons">
  <div class="reasons-inner">
    <div class="reasons-header">
      <div class="reasons-header-left">
        <div class="sec-label">Reasons</div>
        <h2 class="sec-h">選ばれる<em>理由</em></h2>
      </div>
      <div class="reasons-header-right">
        <p class="sec-lead">
          卵アレルギーで卵を諦めてきた方に、安心しておいしく食べてほしい——。<br />
          そんな想いから、原因タンパク「オボムコイド」だけをピンポイントで除去した、世界初のアレルゲン低減卵を開発しました。<br />
          広島大学独自のPlatinum TALEN技術を用いたゲノム編集で、外来遺伝子の挿入は一切なし。全ゲノム解析・キユーピーとの共同検証・相模原病院での臨床研究という3段階で、安全性とおいしさを徹底的に確認しています。
        </p>
      </div>
    </div>
  </div>

  <div class="concepts-grid">
    {
      concepts.map((c) => (
        <article class={`concept-card theme-${c.theme}`}>
          <div class="concept-image">
            <span class="concept-emoji" aria-hidden="true">{c.emoji}</span>
            <div class="concept-text">
              <h3 class="concept-label">{c.label}</h3>
              <p class="concept-sub">{c.sub}</p>
            </div>
          </div>
        </article>
      ))
    }
  </div>
</section>

<style>
  .reasons-section {
    background: linear-gradient(180deg, var(--cream) 0%, #f3ece0 100%);
    padding: 0;
    position: relative;
  }
  .reasons-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  /* ── Header ───────────────────────────────────────── */
  .reasons-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
    padding: 80px 0;
  }
  .reasons-header-left {
    text-align: left;
  }
  .reasons-header-right {
    text-align: left;
  }
  .reasons-header .sec-h {
    font-family: "Noto Sans JP", sans-serif;
  }
  .reasons-header .sec-h em {
    font-style: normal;
  }
  .reasons-header .sec-lead {
    margin: 0;
  }

  /* ── Concept cards (3-up grid) ─────────────────────── */
  .concepts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3px;
  }
  .concept-card {
    background: transparent;
    transition: transform 0.3s ease;
  }
  .concept-card:hover {
    transform: translateY(-4px);
  }

  .concept-image {
    min-height: 50vh;
    position: relative;
    overflow: hidden;
    background-size: cover;
    background-position: center;
  }
  .concept-emoji {
    position: absolute;
    top: 38%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 120px;
    line-height: 1;
    filter: drop-shadow(0 6px 14px rgba(0, 0, 0, 0.18));
    opacity: 0.9;
    pointer-events: none;
  }
  .theme-teal .concept-image {
    background-image: linear-gradient(135deg, var(--teal-p) 0%, #cfe7e3 100%);
  }
  .theme-gold .concept-image {
    background-image: linear-gradient(135deg, var(--gold-p) 0%, #f3dc8f 100%);
  }
  .theme-cream .concept-image {
    background-image: linear-gradient(135deg, #fff5dc 0%, #f6dca3 100%);
  }

  /* Overlay text — placed inside the image, 50px from the bottom */
  .concept-text {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 50px;
    padding: 0 24px;
    text-align: center;
    z-index: 2;
  }
  .concept-label {
    font-family: "Noto Sans JP", sans-serif;
    font-size: 22px;
    font-weight: 700;
    color: var(--dark);
    letter-spacing: 1px;
    margin-bottom: 8px;
  }
  .concept-sub {
    font-size: 13px;
    color: #333333;
    line-height: 1.85;
    font-weight: 400;
    max-width: 280px;
    margin: 0 auto;
  }

  /* ── Responsive ───────────────────────────────────── */
  @media (max-width: 900px) {
    .reasons-header {
      grid-template-columns: 1fr;
      gap: 24px;
      padding: 64px 20px;
    }
    .concepts-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .concept-emoji {
      font-size: 80px;
    }
  }
</style>
