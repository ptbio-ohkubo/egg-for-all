---
// Reasons — BASE FOOD "About" style: header + three concept cards (image + label + sub)
const concepts = [
  {
    img: "https://images.unsplash.com/photo-1578496480240-32d3e0c04525?w=800&h=900&fit=crop&q=80&auto=format",
    label: "ゲノム編集",
    sub: "原因タンパク「オボムコイド」だけを除去",
    theme: "teal",
  },
  {
    img: "https://images.unsplash.com/photo-1570802685082-2224bd954723?w=800&h=900&fit=crop&q=80&auto=format",
    label: "安心・安全",
    sub: "徹底的に安心を確認",
    theme: "gold",
  },
  {
    img: "https://images.unsplash.com/photo-1648170979464-c2384e6f81fb?w=800&h=900&fit=crop&q=80&auto=format",
    label: "おいしい",
    sub: "市販の卵と同じレベルの卵本来の味",
    theme: "cream",
  },
];
---

<section class="reasons-section" id="reasons">
  <div class="reasons-inner">
    <div class="reasons-header">
      <div class="reasons-header-left">
        <div class="sec-label">Reasons</div>
        <h2 class="sec-h">選ばれる<em>理由</em></h2>
      </div>
      <div class="reasons-header-right">
        <p class="sec-lead">
          卵アレルギーで卵を諦めてきた方に、安心しておいしく食べてほしい——。<br />
          そんな想いから、原因タンパク「オボムコイド」だけをピンポイントで除去した、世界初のアレルゲン低減卵を開発しました。<br />
          広島大学独自のPlatinum TALEN技術を用いたゲノム編集で、外来遺伝子の挿入は一切なし。安全性とおいしさを徹底的に確認しています。
        </p>
      </div>
    </div>
  </div>

  <div class="concepts-grid">
    {
      concepts.map((c) => (
        <article class={`concept-card theme-${c.theme}`}>
          <div class="concept-image">
            <img class="concept-img" src={c.img} alt={c.label} />
            <div class="concept-overlay" />
            <div class="concept-text">
              <h3 class="concept-label">{c.label}</h3>
              <p class="concept-sub">{c.sub}</p>
            </div>
          </div>
        </article>
      ))
    }
  </div>
</section>

<style>
  .reasons-section {
    background: linear-gradient(180deg, var(--cream) 0%, #f3ece0 100%);
    padding: 0;
    position: relative;
  }
  .reasons-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  /* ── Header ───────────────────────────────────────── */
  .reasons-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
    padding: 80px 0;
  }
  .reasons-header-left {
    text-align: left;
  }
  .reasons-header-right {
    text-align: left;
  }
  .reasons-header .sec-h {
    font-family: "Noto Sans JP", sans-serif;
  }
  .reasons-header .sec-h em {
    font-style: normal;
  }
  .reasons-header .sec-lead {
    margin: 0;
  }

  /* ── Concept cards (3-up grid) ─────────────────────── */
  .concepts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3px;
  }
  .concept-card {
    background: transparent;
    transition: transform 0.3s ease;
  }
  .concept-card:hover {
    transform: translateY(-4px);
  }

  .concept-image {
    min-height: 50vh;
    position: relative;
    overflow: hidden;
    background: #1a1a1a;
  }

  /* 写真 */
  .concept-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  .concept-card:hover .concept-img {
    transform: scale(1.06);
  }

  /* グラデーションオーバーレイ */
  .concept-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(10, 18, 16, 0.78) 0%,
      rgba(10, 18, 16, 0.25) 55%,
      transparent 100%
    );
    z-index: 1;
  }

  /* Overlay text — placed inside the image, 50px from the bottom */
  .concept-text {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 50px;
    padding: 0 24px;
    text-align: center;
    z-index: 2;
  }
  .concept-label {
    font-family: "Noto Sans JP", sans-serif;
    font-size: 22px;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: 1px;
    margin-bottom: 8px;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
  }
  .concept-sub {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.88);
    line-height: 1.85;
    font-weight: 400;
    max-width: 280px;
    margin: 0 auto;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.4);
  }

  /* ── Responsive ───────────────────────────────────── */
  @media (max-width: 900px) {
    .reasons-header {
      grid-template-columns: 1fr;
      gap: 24px;
      padding: 64px 20px;
    }
    .concepts-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .concept-image {
      min-height: 40vh;
    }
  }
</style>
