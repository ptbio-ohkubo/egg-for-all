---
// Benefit section — key selling points (originally the voice section frame)
// .voice-slider は Hero.astro に移動しました。
const benefits = [
  { icon: "🐣", label: "2027年度", sub: "市場投入予定" },
  { icon: "🧬", label: "Platinum TALEN", sub: "広島大学独自技術" },
  { icon: "📝", label: "認可申請中", sub: "農水省・消費者庁" },
];
---

<section class="benefit-section">
  <div class="voice-inner">
    <div class="benefit-grid">
      {
        benefits.map((b) => (
          <div class="benefit-item">
            <div class="benefit-icon">{b.icon}</div>
            <div class="benefit-label">{b.label}</div>
            <div class="benefit-sub">{b.sub}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .benefit-section {
    background: var(--dark);
    padding: 90px 48px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .benefit-section::before {
    content: "";
    position: absolute;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(255, 255, 255, 0.04) 0%,
      transparent 70%
    );
    top: -200px;
    left: -200px;
  }
  .benefit-section::after {
    content: "";
    position: absolute;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(201, 169, 58, 0.06) 0%,
      transparent 70%
    );
    bottom: -150px;
    right: -150px;
  }
  .voice-inner {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  /* Benefit grid */
  .benefit-grid {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 24px;
    padding: 0 60px;
  }
  .benefit-item {
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 50%;
    width: 160px;
    height: 160px;
    padding: 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    transition: all 0.25s;
  }
  .benefit-item:hover {
    background: rgba(255, 255, 255, 0.14);
    transform: translateY(-3px);
  }
  .benefit-icon {
    font-size: 26px;
    margin-bottom: 6px;
  }
  .benefit-label {
    font-size: 13px;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: 0.3px;
    margin-bottom: 2px;
  }
  .benefit-sub {
    font-size: 11px;
    color: rgba(255, 255, 255, 0.55);
    letter-spacing: 0.2px;
  }

  @media (max-width: 1100px) {
    .benefit-item {
      width: 140px;
      height: 140px;
    }
  }
  @media (max-width: 900px) {
    .benefit-grid {
      padding: 0 20px;
      gap: 12px;
      flex-wrap: wrap;
    }
    .benefit-item {
      width: 120px;
      height: 120px;
    }
  }
  @media (max-width: 699px) {
    .benefit-section {
      padding: 60px 20px;
    }
  }
</style>
