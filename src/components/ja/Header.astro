---
import astroLogo from '../../assets/astro.svg';
import { Icon } from "astro-icon/components";
---

<header id="header">
    <div class="header__top">
        <h1 class="header__top-middle">
            <a href="/">
                PtBio
            </a>
        </h1>
        <ul class="header__top-left" id="header-icons">
            <li class="header__top-left-help">
                <Icon name="mdi:help-circle-outline" size="25" />
            </li>
            <li class="header__top-left-cart">
                <Icon name="mdi:cart-outline" size="25" />
            </li>
            <li class="header__top-left-account">
                <Icon name="mdi:account" size="25" />
            </li>
            <li class="header__top-left-language">
                <Icon name="mdi:earth" size="25" />
            </li>
        </ul>
        <div class="header__top-left header__hamburger">
            <button id="hamburger-toggle" class="header__hamburger-toggle" aria-label="メニュー" aria-expanded="false">
                <Icon name="mdi:menu" size="28" />
            </button>
        </div>
    </div>
    <nav class="header__bottom" id="nav-menu">
        <ul>
            <li>商品一覧</li>
            <li>ブランドについて</li>
            <li>安心安全への取り組み</li>
            <li>あああ</li>
            <li>いいい</li>
        </ul>
    </nav>
</header>

<script>
  (() => {
    const header = document.getElementById("header");

    // <header> の高さを CSS 変数 --header-height に同期する
    if (header) {
      const root = document.documentElement;
      const updateHeaderHeight = () => {
        const h = header.getBoundingClientRect().height;
        root.style.setProperty("--header-height", `${h}px`);
      };

      updateHeaderHeight();

      if (typeof ResizeObserver !== "undefined") {
        const ro = new ResizeObserver(updateHeaderHeight);
        ro.observe(header);
      } else {
        window.addEventListener("resize", updateHeaderHeight);
      }

      // 画像/フォント読み込み後にも再計測
      window.addEventListener("load", updateHeaderHeight);
    }

    const hamburgerBtn = document.getElementById("hamburger-toggle");
    const headerIcons = document.getElementById("header-icons");
    const navMenu = document.getElementById("nav-menu");

    if (!hamburgerBtn || !navMenu) return;

    // ハンバーガーメニューの開閉
    hamburgerBtn.addEventListener("click", () => {
      const isExpanded = hamburgerBtn.getAttribute("aria-expanded") === "true";
      hamburgerBtn.setAttribute("aria-expanded", !isExpanded);
      navMenu.classList.toggle("is-open");
    });

    // ウィンドウリサイズ時に状態をリセット
    window.addEventListener("resize", () => {
      const isTablet = window.matchMedia("(max-width: 748px)").matches;
      if (!isTablet) {
        hamburgerBtn.setAttribute("aria-expanded", "false");
        navMenu.classList.remove("is-open");
      }
    });
  })();
</script>

<style lang="scss">
#header {
  margin: 0;
  padding: 0;
  font-size: 10px;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 9999;
  background-color: rgb(255, 255, 255);
  display: grid;
  grid-template-columns: 1fr;
  grid-template-rows: auto auto;
}
.header {
  &__top {
    height: 100px;
    display: grid;
    grid-template-areas: ". middle left";
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: 1fr;
    justify-content: space-between;
    justify-items: center;
    align-items: center;

    &-middle {
      grid-area: middle;
      align-self: center;
      align-items: center;
      text-align: center;
      margin: 0;
      padding: 0;
    }

    &-left {
      margin: 0 10px 0 0 ;
      padding: 0;
      list-style-type: none;
      grid-area: left;
      display: grid;
      grid-gap: 10px;
      grid-template-columns: repeat(4, 40px);
      grid-template-rows: 40px;
      justify-self: end;
      align-items: center;
      justify-items: center;

      @include mixin.xsm {
        display: none;
      }
    }
  }

  &__bottom {
    margin: 0;
    padding: 0;
    width: 100%;
    align-self: center;
    justify-self: center;
    align-items: center;
    justify-items: center;

    @include mixin.xsm {
      position: fixed;
      top: 100px;
      left: 0;
      width: 100%;
      max-width: 100vw;
      height: 100vh;
      background-color: white;
      transform: translateX(-100%);
      transition: transform 0.3s ease;
      z-index: 9998;

      &.is-open {
        transform: translateX(0);
      }

      & ul {
        grid-template-columns: 1fr;
        grid-template-rows: auto;
        grid-gap: 0;
        padding: 20px 0;

        & li {
          padding: 15px 20px;
          border-bottom: 1px solid #f0f0f0;
          text-align: left;
        }
      }
    }

    & ul {
      margin: 0;
      padding: 15px 10px;
      font-size: 0.8rem;
      list-style-type: none;
      display: grid;
      grid-template-columns: repeat(5, auto);
      grid-template-rows: 1fr;
      grid-gap: 30px;
      align-self: center;
      justify-self: center;

      & li {
        text-align: center;
      }
    }
  }

  &__hamburger {
    display: none;
    background: none;
    border: none;
    padding: 8px;
    cursor: pointer;
    color: inherit;
    margin-right: 10px;
    grid-area: left;

    &-toggle {
      background: none;
    }

    @include mixin.xsm {
      display: flex;
      align-items: center;
      justify-content: center;
    }
  }
}
</style>