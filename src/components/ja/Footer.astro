---
interface FooterLink {
    label: string;
    href: string;
}

interface FooterColumn {
    heading: string;
    links: FooterLink[];
}

const columns: FooterColumn[] = [
    {
        heading: "商品情報",
        links: [
            { label: "商品一覧", href: "#" },
            { label: "新商品", href: "#" },
            { label: "ラインナップ", href: "#lineup" },
        ],
    },
    {
        heading: "ブランド",
        links: [
            { label: "私たちについて", href: "#about" },
            { label: "安心安全への取り組み", href: "#" },
            { label: "サステナビリティ", href: "#" },
        ],
    },
    {
        heading: "サポート",
        links: [
            { label: "よくあるご質問", href: "#" },
            { label: "お問い合わせ", href: "#" },
            { label: "採用情報", href: "#" },
        ],
    },
];

const currentYear = new Date().getFullYear();
---

<footer id="footer" class="footer" role="contentinfo">
    <div class="footer__inner">
        <div class="footer__top">
            <div class="footer__brand">
                <p class="footer__logo">PtBio</p>
                <p class="footer__tagline">
                    ここにブランドのキャッチコピーが入ります。
                </p>
            </div>

            <nav class="footer__nav" aria-label="フッターナビゲーション">
                {columns.map((column) => (
                    <div class="footer__column">
                        <h3 class="footer__column-heading">{column.heading}</h3>
                        <ul class="footer__column-list">
                            {column.links.map((link) => (
                                <li>
                                    <a href={link.href} class="footer__column-link">
                                        {link.label}
                                    </a>
                                </li>
                            ))}
                        </ul>
                    </div>
                ))}
            </nav>
        </div>

        <div class="footer__bottom">
            <small class="footer__copyright">
                &copy; {currentYear} PtBio. All rights reserved.
            </small>
            <ul class="footer__legal">
                <li><a href="#" class="footer__legal-link">プライバシーポリシー</a></li>
                <li><a href="#" class="footer__legal-link">利用規約</a></li>
                <li><a href="#" class="footer__legal-link">特定商取引法に基づく表記</a></li>
            </ul>
        </div>
    </div>
</footer>

<style lang="scss">
.footer {
  padding: 64px 24px 24px;
  background-color: #1a1a1a;
  color: #ddd;

  @include mixin.xsm {
    padding: 48px 16px 16px;
  }

  &__inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  &__top {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 48px;
    padding-bottom: 48px;
    border-bottom: 1px solid #333;

    @include mixin.xsm {
      grid-template-columns: 1fr;
      gap: 32px;
      padding-bottom: 32px;
    }
  }

  &__brand {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  &__logo {
    margin: 0;
    font-size: 24px;
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.05em;
  }

  &__tagline {
    margin: 0;
    font-size: 13px;
    line-height: 1.7;
    color: #aaa;
  }

  &__nav {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;

    @include mixin.xsm {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  &__column-heading {
    margin: 0 0 16px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: #fff;
  }

  &__column-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  &__column-link {
    font-size: 13px;
    color: #bbb;
    text-decoration: none;
    transition: color 0.2s ease;

    &:hover {
      color: #fff;
    }
  }

  &__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    padding-top: 24px;

    @include mixin.xsm {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  &__copyright {
    font-size: 12px;
    color: #888;
  }

  &__legal {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 20px;

    @include mixin.xsm {
      flex-wrap: wrap;
      gap: 12px 20px;
    }
  }

  &__legal-link {
    font-size: 12px;
    color: #888;
    text-decoration: none;
    transition: color 0.2s ease;

    &:hover {
      color: #fff;
    }
  }
}
</style>
