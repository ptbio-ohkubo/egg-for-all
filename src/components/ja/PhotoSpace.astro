---
interface Props {
    src?: string;
    /** 0 (動かない) ～ 1 (通常スクロール速度) くらい。大きいほどゆっくり動く。 */
    speed?: number;
}

// デフォルトで picsum の仮写真を背景に表示。親から src を渡せば差し替え可能。
const {
    src = "https://picsum.photos/seed/ptbio-parallax/1920/900",
    speed = 0.3,
} = Astro.props;
---

<section
    class="photo-space"
    data-parallax
    data-parallax-speed={speed}
    aria-label="メインビジュアル"
>
    <div class="photo-space__frame">
        <div
            class="photo-space__bg"
            style={`background-image: url(${src});`}
            role="img"
        ></div>
    </div>
</section>

<script>
    (() => {
        const prefersReducedMotion = window.matchMedia(
            "(prefers-reduced-motion: reduce)"
        ).matches;
        if (prefersReducedMotion) return;

        const sections = document.querySelectorAll<HTMLElement>("[data-parallax]");
        if (sections.length === 0) return;

        type Target = {
            section: HTMLElement;
            layer: HTMLElement;
            speed: number;
            visible: boolean;
        };

        const targets: Target[] = [];
        sections.forEach((section) => {
            const layer = section.querySelector<HTMLElement>(".photo-space__bg");
            if (!layer) return;
            const speed = Number(section.dataset.parallaxSpeed ?? 0.3);
            targets.push({ section, layer, speed, visible: false });
        });

        if (targets.length === 0) return;

        // 画面外のターゲットは計算をスキップ
        const io = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    const target = targets.find((t) => t.section === entry.target);
                    if (target) target.visible = entry.isIntersecting;
                });
            },
            { rootMargin: "10% 0px" }
        );
        targets.forEach((t) => io.observe(t.section));

        let ticking = false;
        const update = () => {
            const viewportH = window.innerHeight;

            targets.forEach(({ section, layer, speed, visible }) => {
                if (!visible) return;
                const rect = section.getBoundingClientRect();
                // セクション中心と画面中心の差分
                const sectionCenter = rect.top + rect.height / 2;
                const viewportCenter = viewportH / 2;
                const delta = sectionCenter - viewportCenter;
                // delta に speed を掛けた分だけ背景を逆方向にずらす = パララックス
                const translateY = -delta * speed;
                layer.style.transform = `translate3d(0, ${translateY}px, 0)`;
            });

            ticking = false;
        };

        const onScroll = () => {
            if (ticking) return;
            ticking = true;
            window.requestAnimationFrame(update);
        };

        window.addEventListener("scroll", onScroll, { passive: true });
        window.addEventListener("resize", onScroll);
        update();
    })();
</script>

<style lang="scss">
.photo-space {
  padding: 0;
  background-color: #000;

  &__frame {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 6;
    overflow: hidden;

    @include mixin.xsm {
      aspect-ratio: 4 / 3;
    }
  }

  &__bg {
    position: absolute;
    left: 0;
    top: -20%;
    width: 100%;
    // コンテナより高くして、上下に動かせる余白を確保する
    height: 140%;
    background-repeat: no-repeat;
    background-position: center center;
    background-size: cover;
    will-change: transform;
    transform: translate3d(0, 0, 0);
  }
}

@media (prefers-reduced-motion: reduce) {
  .photo-space__bg {
    transform: none !important;
  }
}
</style>
